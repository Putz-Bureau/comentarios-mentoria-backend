{
  "name": "anh-comments-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create anh-comments-db",
    "db:migrate:remote": "wrangler d1 execute anh-comments-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute anh-comments-db --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
